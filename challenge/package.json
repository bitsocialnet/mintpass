{
  "name": "@bitsocial/mintpass-challenge",
  "version": "1.4.1",
  "description": "MintPass pkc-js challenge implementation",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "test": "corepack yarn build && ./scripts/test-with-node.sh",
    "test:manual": "corepack yarn build && cd ../contracts && corepack yarn hardhat test ../challenge/test/mintpass-integration.test.js --network localhost",
    "clean": "rm -rf dist/",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0",
    "release-notes": "conventional-changelog -p angular -r 1 > RELEASE_NOTES.md"
  },
  "dependencies": {
    "@keyv/sqlite": "4.0.8",
    "@pkcprotocol/pkc-logger": "github:pkcprotocol/pkc-logger#cb494fbaf332ed5b2cfd9d9d0f90ca7fd0058b4a",
    "env-paths": "4.0.0",
    "keyv": "5.6.0",
    "multiformats": "^13.1.0",
    "uint8arrays": "^4.0.3",
    "viem": "2.45.0"
  },
  "devDependencies": {
    "@pkcprotocol/pkc-js": "0.0.16",
    "@types/chai": "^4.2.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.7.8",
    "chai": "^4.2.0",
    "conventional-changelog-cli": "^5.0.0",
    "ethers": "6.16.0",
    "hardhat": "^2.28.6",
    "kubo": "0.36.0",
    "tempy": "^3.1.0",
    "typescript": "6.0.3"
  },
  "keywords": [
    "bitsocial",
    "pkc",
    "challenge",
    "nft",
    "mintpass",
    "authentication"
  ],
  "author": "Bitsocial Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bitsocialnet/mintpass",
    "directory": "challenge"
  },
  "packageManager": "yarn@4.13.0"
}
